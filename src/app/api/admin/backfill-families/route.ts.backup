import { NextResponse } from 'next/server';
import { prisma } from '@/lib/prisma';
import { generateLLMResponse } from '@/lib/llm';

export const dynamic = 'force-dynamic';

/**
 * POST: Backfill missing family fields for existing pathogens using LLM classification.
 * GET: Returns the count of pathogens with missing families.
 */
export async function GET() {
    const missing = await prisma.pathogen.count({ where: { OR: [{ family: null }, { family: '' }] } });
    const total = await prisma.pathogen.count();
    return NextResponse.json({ missing, total });
}

export async function POST() {
    const encoder = new TextEncoder();

    const stream = new ReadableStream({
        async start(controller) {
            const send = (msg: string) => controller.enqueue(encoder.encode(JSON.stringify({ message: msg }) + '\n'));

            try {
                const pathogens = await prisma.pathogen.findMany({
                    where: { OR: [{ family: null }, { family: '' }] },
                    select: { id: true, name: true }
                });

                if (pathogens.length === 0) {
                    send('All pathogens already have families assigned.');
                    controller.close();
                    return;
                }

                send(`Found ${pathogens.length} pathogens with missing families. Starting classification...`);

                let updated = 0;
                for (const p of pathogens) {
                    const prompt = `Identify the taxonomic family for the pathogen: "${p.name}".
This could be a virus, bacterium, fungus, or parasite.
Examples: Filoviridae, Flaviviridae, Coronaviridae, Enterobacteriaceae, Candida (genus), Plasmodiidae, Francisellaceae, Hepadnaviridae.
Respond with ONLY the family name — no explanation, no formatting, no punctuation. If truly unknown, respond with "Unknown".`;

                    const response = await generateLLMResponse([
                        { role: 'system', content: 'You are a microbiologist and taxonomist. Provide only the requested taxonomic family name with no additional text.' },
                        { role: 'user', content: prompt }
                    ], 0);

                    let family: string | null = response.trim().replace(/\.$/, '').replace(/["']/g, '');
                    if (family.toLowerCase() === 'unknown' || family.length > 50) {
                        family = null;
                    }

                    if (family) {
                        await prisma.pathogen.update({
                            where: { id: p.id },
                            data: { family }
                        });
                        updated++;
                        send(`✓ ${p.name} → ${family}`);
                    } else {
                        send(`✗ ${p.name} → Could not determine family`);
                    }
                }

                send(`Done. Updated ${updated}/${pathogens.length} pathogens.`);
                controller.close();
            } catch (err: any) {
                send(`Error: ${err.message}`);
                controller.close();
            }
        }
    });

    return new Response(stream, {
        headers: {
            'Content-Type': 'application/x-ndjson',
            'Cache-Control': 'no-cache',
            'Connection': 'keep-alive',
        }
    });
}
