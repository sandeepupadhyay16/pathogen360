generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model MedicalTerm {
  id                    String                 @id @default(uuid())
  name                  String                 @unique
  category              String?
  biology               String?
  description           String?
  synthesizedContext    String?
  synthesisUpdatedAt    DateTime?
  synthesisArticleCount Int?
  synthesisSources      Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  articles              Article[]
  clinicalTrials        ClinicalTrial[]
  knowledgeChunks       KnowledgeChunk[]
  metrics               MedicalMetric[]
  nameEmbeddings        MedicalTermEmbedding[]
  surveillanceAlerts    SurveillanceAlert[]
  logicalQuestions      LogicalQuestion[]
}

model MedicalMetric {
  id            String      @id @default(uuid())
  medicalTermId String
  source        String
  indicator     String
  value         Float
  unit          String?
  year          Int
  location      String
  createdAt     DateTime    @default(now())
  medicalTerm   MedicalTerm @relation(fields: [medicalTermId], references: [id], onDelete: Cascade)
}

model SurveillanceAlert {
  id            String      @id @default(uuid())
  medicalTermId String
  source        String
  title         String
  description   String?
  url           String?
  severity      String?
  publishedAt   DateTime
  createdAt     DateTime    @default(now())
  medicalTerm   MedicalTerm @relation(fields: [medicalTermId], references: [id], onDelete: Cascade)
}

model Article {
  id                  String      @id @default(uuid())
  pubmedId            String
  pmcId               String?
  hasFullText         Boolean     @default(false)
  title               String
  abstractText        String?
  authors             String?
  publicationDate     DateTime?
  countryAffiliations String?
  medicalTermId       String
  createdAt           DateTime    @default(now())
  medicalTerm         MedicalTerm @relation(fields: [medicalTermId], references: [id], onDelete: Cascade)

  @@unique([pubmedId, medicalTermId])
}

model ClinicalTrial {
  id                    String      @id @default(uuid())
  nctId                 String      @unique
  title                 String
  phase                 String?
  status                String?
  overallStatus         String?
  interventionType      String?
  sponsor               String?
  collaborators         String?
  conditions            String?
  locations             String?
  description           String?
  eligibilityCriteria   String?
  enrollment            Int?
  studyDesign           String?
  primaryOutcomes       String?
  secondaryOutcomes     String?
  interventionDetails   String?
  resultsPosted         Boolean     @default(false)
  startDate             DateTime?
  primaryCompletionDate DateTime?
  completionDate        DateTime?
  medicalTermId         String
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  medicalTerm           MedicalTerm @relation(fields: [medicalTermId], references: [id], onDelete: Cascade)
}

model SearchHistory {
  id        String   @id @default(uuid())
  query     String
  response  String?
  createdAt DateTime @default(now())
}

model Conversation {
  id        String    @id @default(uuid())
  title     String    @default("New Conversation")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  role           String
  content        String
  createdAt      DateTime     @default(now())
  reasoning      String?
  usage          Json?
  sources        Json?
  diagnostic     Json?
  routingPath    Json?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model SemanticCache {
  id            String                @id @default(uuid())
  query         String
  embedding     Unsupported("vector")
  response      String
  sources       Json?
  medicalTermId String?
  createdAt     DateTime              @default(now())
}

model MedicalTermEmbedding {
  id            String                @id @default(uuid())
  name          String                @unique
  isAlias       Boolean               @default(false)
  medicalTermId String?
  embedding     Unsupported("vector")
  usageCount    Int                   @default(0)
  createdAt     DateTime              @default(now())
  medicalTerm   MedicalTerm?          @relation(fields: [medicalTermId], references: [id])
}

model KnowledgeChunk {
  id            String                @id @default(uuid())
  medicalTermId String
  sourceType    String
  sourceId      String
  content       String
  embedding     Unsupported("vector")
  createdAt     DateTime              @default(now())
  medicalTerm   MedicalTerm           @relation(fields: [medicalTermId], references: [id], onDelete: Cascade)
}

model Operation {
  id          String         @id @default(uuid())
  type        String
  status      String
  target      String?
  progress    Int            @default(0)
  message     String?
  error       String?
  startedAt   DateTime       @default(now())
  completedAt DateTime?
  durationMs  Int?
  metadata    Json?
  logs        OperationLog[]
}

model OperationLog {
  id          String    @id @default(uuid())
  operationId String
  message     String
  level       String    @default("INFO")
  timestamp   DateTime  @default(now())
  durationMs  Int?
  operation   Operation @relation(fields: [operationId], references: [id], onDelete: Cascade)
}

model LogicalQuestion {
  id             String      @id @default(uuid())
  medicalTermId  String
  question       String
  category       String?
  searchKeywords String?
  answer         String?
  answered       Boolean     @default(false)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  medicalTerm    MedicalTerm @relation(fields: [medicalTermId], references: [id], onDelete: Cascade)
}
